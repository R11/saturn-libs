# libs/saturn-base — header-only lib. Nothing to build.
#
# Provides shared types (saturn_result_t) used by every other lib.
# Consumers add `-I../saturn-base/include` to their CFLAGS and
# `#include <saturn_base/result.h>`.

.PHONY: all test clean
all:
	@echo "saturn-base is header-only; nothing to build."

test:
	@echo "saturn-base has no runtime to test."

clean:
	@:
